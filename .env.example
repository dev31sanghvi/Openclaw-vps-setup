# OpenClaw Official Gateway Configuration
OPENCLAW_GATEWAY_TOKEN=your_secure_random_token_here
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_GATEWAY_BIND=lan

# Core Service Image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Local Configuration Directories (Absolute paths recommended on your VPS)
OPENCLAW_CONFIG_DIR=./openclaw-config
OPENCLAW_WORKSPACE_DIR=./openclaw-workspace

# (Optional) Allow Insecure WebSockets if not using wss:// in local/private network
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=1

# (Optional) Claude Web Settings
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=
